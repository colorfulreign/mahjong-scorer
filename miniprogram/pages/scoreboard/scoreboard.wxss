/* ===== 计分板页面样式 ===== */

.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* ----- 顶部：场风 + 局数 ----- */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #8B0000, #4a0000);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.field-wind {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wind-icon {
  font-size: 64rpx;
}

.wind-label {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
}

.round-info {
  text-align: right;
}

.round-num {
  font-size: 36rpx;
  color: #ffd700;
  font-weight: bold;
}

/* ----- 四人卡片 ----- */
.player-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.player-card {
  background: #252547;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  border: 3rpx solid transparent;
  transition: border-color 0.3s;
}

.player-card.is-dealer {
  border-color: #ffd700;
  background: #2a2535;
}

.player-card.is-winner {
  border-color: #ff6b6b;
  background: #2a2025;
}

.player-wind {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.wind-emoji {
  font-size: 52rpx;
}

.wind-emoji.wind-东 { }
.wind-emoji.wind-南 { }
.wind-emoji.wind-西 { }
.wind-emoji.wind-北 { }

.player-info {
  margin-bottom: 12rpx;
}

.player-name {
  font-size: 28rpx;
  color: #e8d5b7;
  display: block;
}

.player-wind-label {
  font-size: 22rpx;
  color: #888;
}

.player-total {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.total-label {
  font-size: 20rpx;
  color: #888;
}

.total-score {
  font-size: 40rpx;
  font-weight: bold;
}

.total-score.positive { color: #ff6b6b; }
.total-score.negative { color: #6bcb77; }

/* ----- 得分输入区 ----- */
.score-input-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 24rpx;
}

.input-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #333;
}

.input-row:last-child {
  border-bottom: none;
}

.input-player {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 200rpx;
}

.input-wind-emoji {
  font-size: 40rpx;
}

.input-name {
  font-size: 28rpx;
  color: #e8d5b7;
}

.input-field-wrap {
  flex: 1;
  text-align: center;
}

.score-input {
  background: #1a1a2e !important;
  color: #ffd700 !important;
  border: 2rpx solid #8B0000 !important;
  border-radius: 8rpx !important;
  padding: 12rpx 24rpx !important;
  font-size: 36rpx !important;
  text-align: center !important;
  width: 180rpx !important;
  height: 72rpx !important;
  line-height: 48rpx !important;
}

.input-equals {
  width: 100rpx;
  text-align: right;
  font-size: 28rpx;
  color: #888;
}

/* ----- 校验提示 ----- */
.validation-msg {
  text-align: center;
  margin-top: 16rpx;
}

.validation-msg .ok {
  color: #6bcb77;
  font-size: 26rpx;
}

.validation-msg .error {
  color: #ff6b6b;
  font-size: 26rpx;
}

/* ----- 快速填分 ----- */
.quick-fill {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #333;
}

.hint-text {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 12rpx;
}

.quick-btns {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.quick-btn {
  font-size: 22rpx !important;
  background: #3a3a5c !important;
  color: #ccc !important;
  border: 1rpx solid #555 !important;
  border-radius: 8rpx !important;
  padding: 8rpx 16rpx !important;
}

/* ----- 操作按钮 ----- */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #8B0000, #c41e3a);
  color: #ffd700;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 36rpx;
  font-weight: bold;
}

.btn-primary[disabled] {
  opacity: 0.4;
}

.btn-secondary {
  background: #3a3a5c;
  color: #ccc;
  border: 1rpx solid #555;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-danger {
  background: transparent;
  color: #999;
  border: 1rpx solid #555;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

/* ----- 历史记录 ----- */
.history-section {
  margin-bottom: 48rpx;
}

.empty-hint {
  text-align: center;
  color: #666;
  font-size: 26rpx;
  padding: 32rpx;
}

.round-record {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #333;
}

.round-record:last-child {
  border-bottom: none;
}

.record-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.record-round {
  font-size: 26rpx;
  color: #ffd700;
  font-weight: bold;
}

.record-wind {
  font-size: 24rpx;
  color: #888;
}

.record-winner {
  font-size: 24rpx;
  color: #ff6b6b;
}

.record-scores {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding-left: 8rpx;
}

.record-score {
  font-size: 24rpx;
}

.record-score.positive {
  color: #ff6b6b;
}

.record-score.negative {
  color: #6bcb77;
}

.record-score.zero {
  color: #666;
}

/* 庄家标识 */
.dealer-badge {
  background: #8B0000;
  color: #ffd700;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}
